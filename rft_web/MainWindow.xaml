<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Rft_Wpf_Web"
    xmlns:shell="http://schemas.microsoft.com/winfx/2006/xaml/presentation/shell" xmlns:Wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" x:Class="Rft_Wpf_Web.MainWindow"
    WindowStyle="None"
    mc:Ignorable="d"
    Background="#483D8B"
    MaxHeight="{x:Static SystemParameters.MaximizedPrimaryScreenHeight}"
    WindowState="Maximized"
    Title="MainWindow" Height="450" Width="800"
    >

    <WindowChrome.WindowChrome>
        <!-- CaptionHeight defines the draggable area (e.g., 32px) -->
        <WindowChrome 
                  GlassFrameThickness="0" CaptionHeight="40" CornerRadius="0" ResizeBorderThickness="8" />
    </WindowChrome.WindowChrome>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="767*"/>
            <ColumnDefinition Width="23*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <!-- Custom Title Bar Row -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Your custom Title Bar -->
        <Border Grid.Row="0" Background="DarkSlateBlue" Grid.ColumnSpan="2">
            <DockPanel LastChildFill="True">
                <TextBlock Text="RFT WEB APP" Foreground="White" FontSize="15" Margin="10,6"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True" HorizontalAlignment="Right">
                    <Button Content="−" Height="25" Width="25" Click="MinimizeClick" Margin="4"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button Content="▢" Height="25" Width="25" Click="MaximizeClick" Margin="4"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button Content="✕" Height="25" Width="25" Click="CloseClick" Background="Red" Margin="4"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content goes here -->
        <Grid Grid.Row="1" Background="White" Grid.ColumnSpan="2">
            <Wpf:WebView2 x:Name="mainWebView" Margin="0"/>
        </Grid>
    </Grid>
</Window>
